{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milu.studio/schemas/skills/video_generation/output.schema.json",
  "title": "video_generation output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "skill_name", "schema_version", "data", "error", "runtime"],
  "properties": {
    "ok": { "type": "boolean" },
    "skill_name": { "type": "string", "const": "video_generation" },
    "schema_version": { "type": "string", "const": "1.0" },
    "data": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": [
            "project_id",
            "episode_index",
            "title",
            "language",
            "provider",
            "model",
            "mode",
            "clips",
            "clip_manifest",
            "cost_estimate",
            "review",
            "checkpoint"
          ],
          "properties": {
            "project_id": { "type": "string" },
            "episode_index": { "type": "integer" },
            "title": { "type": "string" },
            "language": { "type": "string" },
            "provider": { "type": "string", "const": "mock" },
            "model": { "type": "string", "const": "none" },
            "mode": { "type": "string" },
            "clips": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "clip_id",
                  "request_id",
                  "shot_id",
                  "shot_index",
                  "duration_seconds",
                  "status",
                  "provider",
                  "model",
                  "generation_mode",
                  "prompt",
                  "negative_prompt",
                  "source_images",
                  "aspect_ratio",
                  "selected",
                  "file_written",
                  "asset_uri",
                  "storage_intent",
                  "metadata"
                ],
                "properties": {
                  "clip_id": { "type": "string" },
                  "request_id": { "type": "string" },
                  "shot_id": { "type": "string" },
                  "shot_index": { "type": "integer" },
                  "duration_seconds": { "type": "integer" },
                  "status": { "type": "string" },
                  "provider": { "type": "string", "const": "mock" },
                  "model": { "type": "string", "const": "none" },
                  "generation_mode": { "type": "string" },
                  "prompt": { "type": "string" },
                  "negative_prompt": { "type": "array", "items": { "type": "string" } },
                  "source_images": { "type": "array", "items": { "type": "object" } },
                  "aspect_ratio": { "type": "string" },
                  "selected": { "type": "boolean" },
                  "file_written": { "type": "boolean", "const": false },
                  "asset_uri": { "type": "string" },
                  "storage_intent": { "type": "object" },
                  "metadata": { "type": "object" }
                }
              }
            },
            "clip_manifest": { "type": "object" },
            "cost_estimate": { "type": "object" },
            "review": { "type": "object" },
            "checkpoint": { "type": "object" }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "required": ["duration_ms", "model", "mode", "cost_estimate"],
      "properties": {
        "duration_ms": { "type": "number" },
        "model": { "type": "string" },
        "mode": { "type": "string" },
        "cost_estimate": { "type": "number" }
      }
    }
  }
}
