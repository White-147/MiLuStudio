{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milu.studio/schemas/skills/storyboard_director/output.schema.json",
  "title": "storyboard_director output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "skill_name", "schema_version", "data", "error", "runtime"],
  "properties": {
    "ok": { "type": "boolean" },
    "skill_name": { "type": "string", "const": "storyboard_director" },
    "schema_version": { "type": "string", "const": "1.0" },
    "data": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": [
            "project_id",
            "episode_index",
            "title",
            "language",
            "target_duration_seconds",
            "aspect_ratio",
            "storyboard_summary",
            "shots",
            "timing_summary",
            "image_video_readiness",
            "review",
            "checkpoint"
          ],
          "properties": {
            "project_id": { "type": "string" },
            "episode_index": { "type": "integer" },
            "title": { "type": "string" },
            "language": { "type": "string" },
            "target_duration_seconds": { "type": "integer", "minimum": 30, "maximum": 60 },
            "aspect_ratio": { "type": "string" },
            "storyboard_summary": { "type": "string" },
            "shots": {
              "type": "array",
              "minItems": 6,
              "maxItems": 12,
              "items": {
                "type": "object",
                "required": [
                  "shot_id",
                  "shot_index",
                  "source_segment_id",
                  "start_second",
                  "duration_seconds",
                  "scene",
                  "characters",
                  "shot_size",
                  "camera",
                  "lighting",
                  "visual_action",
                  "dialogue",
                  "narration",
                  "sound_note",
                  "style_prompt_block_refs",
                  "continuity_notes",
                  "image_prompt_seed",
                  "video_prompt_seed",
                  "review_flags"
                ],
                "properties": {
                  "shot_id": { "type": "string" },
                  "shot_index": { "type": "integer" },
                  "source_segment_id": { "type": "string" },
                  "source_beat_id": { "type": "string" },
                  "start_second": { "type": "integer" },
                  "duration_seconds": { "type": "integer" },
                  "scene": { "type": "string" },
                  "characters": { "type": "array", "items": { "type": "object" } },
                  "shot_size": { "type": "string" },
                  "camera": { "type": "object" },
                  "lighting": { "type": "object" },
                  "visual_action": { "type": "string" },
                  "dialogue": { "type": "array", "items": { "type": "object" } },
                  "narration": { "type": "string" },
                  "sound_note": { "type": "string" },
                  "style_prompt_block_refs": { "type": "array", "items": { "type": "string" } },
                  "continuity_notes": { "type": "array", "items": { "type": "string" } },
                  "image_prompt_seed": { "type": "string" },
                  "video_prompt_seed": { "type": "string" },
                  "review_flags": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "timing_summary": { "type": "object" },
            "image_video_readiness": { "type": "object" },
            "review": { "type": "object" },
            "checkpoint": { "type": "object" }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "required": ["duration_ms", "model", "mode", "cost_estimate"],
      "properties": {
        "duration_ms": { "type": "number" },
        "model": { "type": "string" },
        "mode": { "type": "string" },
        "cost_estimate": { "type": "number" }
      }
    }
  }
}

