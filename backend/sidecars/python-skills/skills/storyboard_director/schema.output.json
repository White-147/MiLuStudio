{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milu.studio/schemas/skills/storyboard_director/output.schema.json",
  "title": "storyboard_director output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "skill_name", "schema_version", "data", "error", "runtime"],
  "properties": {
    "ok": { "type": "boolean" },
    "skill_name": { "type": "string", "const": "storyboard_director" },
    "schema_version": { "type": "string", "const": "1.0" },
    "data": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": [
            "project_id",
            "episode_index",
            "title",
            "language",
            "target_duration_seconds",
            "aspect_ratio",
            "storyboard_summary",
            "shots",
            "format_profile",
            "film_overview",
            "storyboard_parts",
            "rendered_markdown",
            "validation_report",
            "timing_summary",
            "image_video_readiness",
            "review",
            "checkpoint"
          ],
          "properties": {
            "project_id": { "type": "string" },
            "episode_index": { "type": "integer" },
            "title": { "type": "string" },
            "language": { "type": "string" },
            "target_duration_seconds": { "type": "integer", "minimum": 30, "maximum": 60 },
            "aspect_ratio": { "type": "string" },
            "storyboard_summary": { "type": "string" },
            "shots": {
              "type": "array",
              "minItems": 6,
              "maxItems": 12,
              "items": {
                "type": "object",
                "required": [
                  "shot_id",
                  "shot_index",
                  "source_segment_id",
                  "start_second",
                  "duration_seconds",
                  "scene",
                  "characters",
                  "shot_size",
                  "camera",
                  "lighting",
                  "visual_action",
                  "dialogue",
                  "narration",
                  "sound_note",
                  "style_prompt_block_refs",
                  "continuity_notes",
                  "image_prompt_seed",
                  "video_prompt_seed",
                  "review_flags"
                ],
                "properties": {
                  "shot_id": { "type": "string" },
                  "shot_index": { "type": "integer" },
                  "source_segment_id": { "type": "string" },
                  "source_beat_id": { "type": "string" },
                  "start_second": { "type": "integer" },
                  "duration_seconds": { "type": "integer" },
                  "scene": { "type": "string" },
                  "characters": { "type": "array", "items": { "type": "object" } },
                  "shot_size": { "type": "string" },
                  "camera": { "type": "object" },
                  "lighting": { "type": "object" },
                  "visual_action": { "type": "string" },
                  "dialogue": { "type": "array", "items": { "type": "object" } },
                  "narration": { "type": "string" },
                  "sound_note": { "type": "string" },
                  "style_prompt_block_refs": { "type": "array", "items": { "type": "string" } },
                  "continuity_notes": { "type": "array", "items": { "type": "string" } },
                  "image_prompt_seed": { "type": "string" },
                  "video_prompt_seed": { "type": "string" },
                  "review_flags": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "format_profile": {
              "type": "object",
              "required": ["name", "mode", "strict_md_ready", "notes"],
              "properties": {
                "name": { "type": "string" },
                "mode": { "type": "string" },
                "strict_md_ready": { "type": "boolean" },
                "notes": { "type": "array", "items": { "type": "string" } }
              }
            },
            "film_overview": {
              "type": "object",
              "required": [
                "episode_label",
                "theme",
                "total_duration_seconds",
                "target_duration_seconds",
                "shot_count",
                "style_tone",
                "camera_setup"
              ],
              "properties": {
                "episode_label": { "type": "string" },
                "theme": { "type": "string" },
                "total_duration_seconds": { "type": "integer" },
                "target_duration_seconds": { "type": "integer" },
                "shot_count": { "type": "integer" },
                "style_tone": { "type": "string" },
                "camera_setup": { "type": "string" }
              }
            },
            "storyboard_parts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "part_id",
                  "part_index",
                  "title",
                  "start_second",
                  "end_second",
                  "duration_seconds",
                  "time_weather_light",
                  "camera_setup",
                  "cast_and_props",
                  "absolute_blocking",
                  "style",
                  "shots"
                ],
                "properties": {
                  "part_id": { "type": "string" },
                  "part_index": { "type": "integer" },
                  "title": { "type": "string" },
                  "start_second": { "type": "integer" },
                  "end_second": { "type": "integer" },
                  "duration_seconds": { "type": "integer" },
                  "time_weather_light": { "type": "string" },
                  "camera_setup": { "type": "string" },
                  "cast_and_props": { "type": "string" },
                  "absolute_blocking": { "type": "string" },
                  "style": { "type": "string" },
                  "shots": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": [
                        "shot_label",
                        "duration_seconds",
                        "environment_description",
                        "time_slice",
                        "shot_size",
                        "camera_movement",
                        "sound_effect",
                        "background_music"
                      ],
                      "properties": {
                        "shot_label": { "type": "string" },
                        "local_shot_index": { "type": "integer" },
                        "source_shot_id": { "type": "string" },
                        "duration_seconds": { "type": "integer" },
                        "environment_description": { "type": "string" },
                        "time_slice": { "type": "string" },
                        "shot_size": { "type": "string" },
                        "camera_movement": { "type": "string" },
                        "sound_effect": { "type": "string" },
                        "background_music": { "type": "string" },
                        "dialogue": { "type": "string" },
                        "narration": { "type": "string" }
                      }
                    }
                  }
                }
              }
            },
            "rendered_markdown": { "type": "string" },
            "validation_report": {
              "type": "object",
              "required": ["profile", "strict_md_ready", "checks", "deferred_requirements"],
              "properties": {
                "profile": { "type": "string" },
                "strict_md_ready": { "type": "boolean" },
                "checks": { "type": "array", "items": { "type": "object" } },
                "deferred_requirements": { "type": "array", "items": { "type": "string" } }
              }
            },
            "timing_summary": { "type": "object" },
            "image_video_readiness": { "type": "object" },
            "review": { "type": "object" },
            "checkpoint": { "type": "object" }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "required": ["duration_ms", "model", "mode", "cost_estimate"],
      "properties": {
        "duration_ms": { "type": "number" },
        "model": { "type": "string" },
        "mode": { "type": "string" },
        "cost_estimate": { "type": "number" }
      }
    }
  }
}
