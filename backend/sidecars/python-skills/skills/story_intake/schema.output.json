{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milu.studio/schemas/skills/story_intake/output.schema.json",
  "title": "story_intake output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "skill_name", "schema_version", "data", "error", "runtime"],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "skill_name": {
      "type": "string",
      "const": "story_intake"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "data": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "project_id",
            "language",
            "source_word_count",
            "summary",
            "logline",
            "genres",
            "tone_keywords",
            "style_preset",
            "mode",
            "target_duration_seconds",
            "aspect_ratio",
            "recommended_shot_count",
            "main_characters",
            "story_beats",
            "risks",
            "checkpoint"
          ],
          "properties": {
            "project_id": { "type": "string" },
            "language": { "type": "string" },
            "source_word_count": { "type": "integer", "minimum": 0 },
            "summary": { "type": "string" },
            "logline": { "type": "string" },
            "genres": { "type": "array", "items": { "type": "string" } },
            "tone_keywords": { "type": "array", "items": { "type": "string" } },
            "style_preset": { "type": "string" },
            "mode": { "type": "string" },
            "target_duration_seconds": { "type": "integer" },
            "aspect_ratio": { "type": "string" },
            "recommended_shot_count": { "type": "integer" },
            "main_characters": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "role", "evidence"],
                "properties": {
                  "name": { "type": "string" },
                  "role": { "type": "string" },
                  "evidence": { "type": "string" }
                }
              }
            },
            "story_beats": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["index", "label", "summary"],
                "properties": {
                  "index": { "type": "integer" },
                  "label": { "type": "string" },
                  "summary": { "type": "string" }
                }
              }
            },
            "risks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["code", "severity", "message"],
                "properties": {
                  "code": { "type": "string" },
                  "severity": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            },
            "checkpoint": {
              "type": "object",
              "required": ["required", "policy", "reason"],
              "properties": {
                "required": { "type": "boolean" },
                "policy": { "type": "string" },
                "reason": { "type": "string" }
              }
            }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "required": ["duration_ms", "model", "mode", "cost_estimate"],
      "properties": {
        "duration_ms": { "type": "number" },
        "model": { "type": "string" },
        "mode": { "type": "string" },
        "cost_estimate": { "type": "number" }
      }
    }
  }
}
