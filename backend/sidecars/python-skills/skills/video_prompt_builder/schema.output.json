{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milu.studio/schemas/skills/video_prompt_builder/output.schema.json",
  "title": "video_prompt_builder output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "skill_name", "schema_version", "data", "error", "runtime"],
  "properties": {
    "ok": { "type": "boolean" },
    "skill_name": { "type": "string", "const": "video_prompt_builder" },
    "schema_version": { "type": "string", "const": "1.0" },
    "data": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": [
            "project_id",
            "episode_index",
            "title",
            "language",
            "aspect_ratio",
            "prompt_set_id",
            "video_requests",
            "negative_prompt",
            "source_asset_manifest",
            "generation_plan",
            "review",
            "checkpoint"
          ],
          "properties": {
            "project_id": { "type": "string" },
            "episode_index": { "type": "integer" },
            "title": { "type": "string" },
            "language": { "type": "string" },
            "aspect_ratio": { "type": "string" },
            "prompt_set_id": { "type": "string" },
            "video_requests": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "request_id",
                  "shot_id",
                  "shot_index",
                  "duration_seconds",
                  "aspect_ratio",
                  "generation_mode",
                  "prompt",
                  "negative_prompt",
                  "source_images",
                  "motion_plan",
                  "continuity_refs",
                  "seed_hint",
                  "output_slot"
                ],
                "properties": {
                  "request_id": { "type": "string" },
                  "shot_id": { "type": "string" },
                  "shot_index": { "type": "integer" },
                  "duration_seconds": { "type": "integer" },
                  "aspect_ratio": { "type": "string" },
                  "generation_mode": { "type": "string" },
                  "prompt": { "type": "string" },
                  "negative_prompt": { "type": "array", "items": { "type": "string" } },
                  "source_images": { "type": "array", "items": { "type": "object" } },
                  "character_reference_asset_ids": { "type": "array", "items": { "type": "string" } },
                  "motion_plan": { "type": "object" },
                  "continuity_refs": { "type": "array", "items": { "type": "string" } },
                  "seed_hint": { "type": "string" },
                  "output_slot": { "type": "object" }
                }
              }
            },
            "negative_prompt": { "type": "array", "items": { "type": "string" } },
            "source_asset_manifest": { "type": "object" },
            "generation_plan": { "type": "object" },
            "review": { "type": "object" },
            "checkpoint": { "type": "object" }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "required": ["duration_ms", "model", "mode", "cost_estimate"],
      "properties": {
        "duration_ms": { "type": "number" },
        "model": { "type": "string" },
        "mode": { "type": "string" },
        "cost_estimate": { "type": "number" }
      }
    }
  }
}
