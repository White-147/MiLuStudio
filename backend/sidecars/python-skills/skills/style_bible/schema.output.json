{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milu.studio/schemas/skills/style_bible/output.schema.json",
  "title": "style_bible output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "skill_name", "schema_version", "data", "error", "runtime"],
  "properties": {
    "ok": { "type": "boolean" },
    "skill_name": { "type": "string", "const": "style_bible" },
    "schema_version": { "type": "string", "const": "1.0" },
    "data": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": [
            "project_id",
            "episode_index",
            "title",
            "language",
            "style_name",
            "visual_style",
            "color_palette",
            "lighting",
            "environment_design",
            "camera_language",
            "character_rendering_rules",
            "negative_prompt",
            "reusable_prompt_blocks",
            "image_prompt_guidelines",
            "video_prompt_guidelines",
            "continuity_notes",
            "review",
            "checkpoint"
          ],
          "properties": {
            "project_id": { "type": "string" },
            "episode_index": { "type": "integer" },
            "title": { "type": "string" },
            "language": { "type": "string" },
            "style_name": { "type": "string" },
            "visual_style": { "type": "object" },
            "color_palette": {
              "type": "array",
              "minItems": 4,
              "items": {
                "type": "object",
                "required": ["name", "hex", "usage"],
                "properties": {
                  "name": { "type": "string" },
                  "hex": { "type": "string" },
                  "usage": { "type": "string" }
                }
              }
            },
            "lighting": { "type": "object" },
            "environment_design": { "type": "object" },
            "camera_language": { "type": "object" },
            "character_rendering_rules": { "type": "array", "items": { "type": "object" } },
            "negative_prompt": { "type": "array", "items": { "type": "string" } },
            "reusable_prompt_blocks": { "type": "object" },
            "image_prompt_guidelines": { "type": "array", "items": { "type": "string" } },
            "video_prompt_guidelines": { "type": "array", "items": { "type": "string" } },
            "continuity_notes": { "type": "array", "items": { "type": "string" } },
            "review": { "type": "object" },
            "checkpoint": { "type": "object" }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "required": ["duration_ms", "model", "mode", "cost_estimate"],
      "properties": {
        "duration_ms": { "type": "number" },
        "model": { "type": "string" },
        "mode": { "type": "string" },
        "cost_estimate": { "type": "number" }
      }
    }
  }
}

