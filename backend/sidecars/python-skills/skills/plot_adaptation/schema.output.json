{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milu.studio/schemas/skills/plot_adaptation/output.schema.json",
  "title": "plot_adaptation output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "skill_name", "schema_version", "data", "error", "runtime"],
  "properties": {
    "ok": { "type": "boolean" },
    "skill_name": { "type": "string", "const": "plot_adaptation" },
    "schema_version": { "type": "string", "const": "1.0" },
    "data": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": [
            "project_id",
            "language",
            "title",
            "logline",
            "target_duration_seconds",
            "aspect_ratio",
            "mode",
            "style_preset",
            "genre_tags",
            "tone_keywords",
            "main_characters",
            "adaptation_strategy",
            "plot_beats",
            "core_conflict",
            "turning_point",
            "ending_hook",
            "continuity_notes",
            "review_points",
            "risks",
            "checkpoint"
          ],
          "properties": {
            "project_id": { "type": "string" },
            "language": { "type": "string" },
            "title": { "type": "string" },
            "logline": { "type": "string" },
            "target_duration_seconds": { "type": "integer", "minimum": 30, "maximum": 60 },
            "aspect_ratio": { "type": "string" },
            "mode": { "type": "string" },
            "style_preset": { "type": "string" },
            "genre_tags": { "type": "array", "items": { "type": "string" } },
            "tone_keywords": { "type": "array", "items": { "type": "string" } },
            "main_characters": { "type": "array", "items": { "type": "object" } },
            "adaptation_strategy": { "type": "object" },
            "plot_beats": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": {
                "type": "object",
                "required": [
                  "beat_id",
                  "label",
                  "purpose",
                  "summary",
                  "estimated_seconds",
                  "emotional_value",
                  "required_characters"
                ],
                "properties": {
                  "beat_id": { "type": "string" },
                  "label": { "type": "string" },
                  "purpose": { "type": "string" },
                  "summary": { "type": "string" },
                  "estimated_seconds": { "type": "integer" },
                  "emotional_value": { "type": "string" },
                  "required_characters": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "core_conflict": { "type": "string" },
            "turning_point": { "type": "string" },
            "ending_hook": { "type": "string" },
            "continuity_notes": { "type": "array", "items": { "type": "string" } },
            "review_points": { "type": "array", "items": { "type": "string" } },
            "risks": { "type": "array", "items": { "type": "object" } },
            "checkpoint": { "type": "object" }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "required": ["duration_ms", "model", "mode", "cost_estimate"],
      "properties": {
        "duration_ms": { "type": "number" },
        "model": { "type": "string" },
        "mode": { "type": "string" },
        "cost_estimate": { "type": "number" }
      }
    }
  }
}
