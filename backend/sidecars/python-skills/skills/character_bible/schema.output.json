{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milu.studio/schemas/skills/character_bible/output.schema.json",
  "title": "character_bible output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "skill_name", "schema_version", "data", "error", "runtime"],
  "properties": {
    "ok": { "type": "boolean" },
    "skill_name": { "type": "string", "const": "character_bible" },
    "schema_version": { "type": "string", "const": "1.0" },
    "data": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": [
            "project_id",
            "episode_index",
            "title",
            "language",
            "source_summary",
            "characters",
            "relationship_notes",
            "continuity_rules",
            "review",
            "checkpoint"
          ],
          "properties": {
            "project_id": { "type": "string" },
            "episode_index": { "type": "integer" },
            "title": { "type": "string" },
            "language": { "type": "string" },
            "source_summary": { "type": "string" },
            "characters": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "character_id",
                  "name",
                  "role_type",
                  "stable_seed",
                  "identity",
                  "personality",
                  "appearance",
                  "costume",
                  "voice_profile",
                  "visual_identity",
                  "expression_palette",
                  "continuity_rules",
                  "source_evidence"
                ],
                "properties": {
                  "character_id": { "type": "string" },
                  "name": { "type": "string" },
                  "role_type": { "type": "string" },
                  "stable_seed": { "type": "string" },
                  "identity": { "type": "string" },
                  "personality": { "type": "array", "items": { "type": "string" } },
                  "appearance": { "type": "object" },
                  "costume": { "type": "object" },
                  "voice_profile": { "type": "object" },
                  "visual_identity": { "type": "object" },
                  "expression_palette": { "type": "array", "items": { "type": "object" } },
                  "continuity_rules": { "type": "array", "items": { "type": "string" } },
                  "source_evidence": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "relationship_notes": { "type": "array", "items": { "type": "string" } },
            "continuity_rules": { "type": "array", "items": { "type": "string" } },
            "review": { "type": "object" },
            "checkpoint": { "type": "object" }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "required": ["duration_ms", "model", "mode", "cost_estimate"],
      "properties": {
        "duration_ms": { "type": "number" },
        "model": { "type": "string" },
        "mode": { "type": "string" },
        "cost_estimate": { "type": "number" }
      }
    }
  }
}

