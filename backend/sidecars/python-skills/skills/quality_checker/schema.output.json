{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milu.studio/schemas/skills/quality_checker/output.schema.json",
  "title": "quality_checker output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "skill_name", "schema_version", "data", "error", "runtime"],
  "properties": {
    "ok": { "type": "boolean" },
    "skill_name": { "type": "string", "const": "quality_checker" },
    "schema_version": { "type": "string", "const": "1.0" },
    "data": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": [
            "project_id",
            "episode_index",
            "title",
            "language",
            "provider",
            "model",
            "mode",
            "quality_status",
            "score",
            "issues",
            "auto_retry_items",
            "manual_review_items",
            "quality_manifest",
            "generation_plan",
            "review",
            "checkpoint"
          ],
          "properties": {
            "project_id": { "type": "string" },
            "episode_index": { "type": "integer" },
            "title": { "type": "string" },
            "language": { "type": "string" },
            "provider": { "type": "string", "const": "none" },
            "model": { "type": "string", "const": "none" },
            "mode": { "type": "string" },
            "quality_status": {
              "type": "string",
              "enum": ["passed", "passed_with_warnings", "needs_review", "blocked"]
            },
            "score": { "type": "object" },
            "issues": { "type": "array", "items": { "type": "object" } },
            "auto_retry_items": { "type": "array", "items": { "type": "object" } },
            "manual_review_items": { "type": "array", "items": { "type": "object" } },
            "quality_manifest": { "type": "object" },
            "generation_plan": { "type": "object" },
            "review": { "type": "object" },
            "checkpoint": { "type": "object" }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "required": ["duration_ms", "model", "mode", "cost_estimate"],
      "properties": {
        "duration_ms": { "type": "number" },
        "model": { "type": "string" },
        "mode": { "type": "string" },
        "cost_estimate": { "type": "number" }
      }
    }
  }
}
