{
  "name": "@milu-studio/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:local": "powershell -ExecutionPolicy Bypass -File ../../scripts/windows/Start-MiLuStudioWebDev.ps1",
    "services:start": "powershell -ExecutionPolicy Bypass -File ../../scripts/windows/Start-MiLuStudioLocalServices.ps1",
    "services:stop": "powershell -ExecutionPolicy Bypass -File ../../scripts/windows/Stop-MiLuStudioLocalServices.ps1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.9.0",
    "vite": "^8.0.12"
  }
}
